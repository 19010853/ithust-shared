{
  "version": "0.0.10",
  "license": "MIT",
  "main": "index.js",
  "description": "Helpers library for ITHust app",
  "files": [
    "build/",
    "package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && tsc --outDir build/src && node scripts/build-package.js",
    "build:cjs": "cross-env NODE_ENV=production BABEL_ENV=cjs babel src --presets=./scripts/babel-preset.js --extensions .ts,.tsx --ignore src/**/*.specs.tsx --out-dir build/cjs --source-maps",
    "build:esm": "cross-env NODE_ENV=production BABEL_ENV=esm babel src --presets=./scripts/babel-preset.js --extensions .ts,.tsx --ignore src/**/*.specs.tsx --out-dir build/esm --source-maps"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "keywords": [],
  "name": "@19010853/ithust-shared",
  "author": "グエン・ミン・コイ",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/19010853/ithust-shared.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "import": "./build/esm/index.js",
      "require": "./build/cjs/index.js"
    },
    "./icons": {
      "import": "./build/esm/icons/index.js",
      "require": "./build/cjs/icons/index.js"
    }
  },
  "types": "./build/src/index.d.ts",
  "dependencies": {
    "@elastic/elasticsearch": "^9.1.1",
    "cloudinary": "^2.7.0",
    "express": "^5.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.0",
    "typescript": "^5.9.3",
    "winston": "^3.18.3",
    "winston-elasticsearch": "^0.19.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "cross-env": "^10.1.0"
  }
}
